# PostgreSQL
POSTGRES_USER=dataline
POSTGRES_PASSWORD=dataline
POSTGRES_DB=dataline
POSTGRES_PORT=5432

# Server
SERVER_PORT=8000
DATALINE_DATABASE_URL=postgresql://dataline:dataline@localhost:5432/dataline
DATALINE_CORS_ORIGINS=["http://localhost:3000"]
DATALINE_DEBUG=false

# Admin
ADMIN_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# 单独构建/启动 admin 时：Next 构建期反代目标（ingestor API 根 URL，无 /api 后缀）
# Linux Docker 常用 host.docker.internal（compose 已加 extra_hosts）；也可填公网/内网 API 地址
ADMIN_BUILD_BACKEND_URL=http://host.docker.internal:8000
